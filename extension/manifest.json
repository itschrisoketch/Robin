{
  "manifest_version": 3,
  "name": "Robin — a path into Bitcoin open source",
  "version": "0.1.0",
  "description": "Tells prospective Bitcoin OSS contributors what to work on, what to read first, and when not to contribute yet — right on the GitHub page.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Robin"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["presets.js", "render.js", "content.js"],
      "css": ["robin.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["https://github.com/*"]
    }
  ]
}
